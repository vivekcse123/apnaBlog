{
  "outputDirectory": "dist/blog-app/browser",
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.csr.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}